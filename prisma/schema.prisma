generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ReservationStatus {
  DRAFT
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  EXPIRED
  MANUAL_BLOCK
  COMPLETED
}

enum PaymentStatus {
  CREATED
  LINK_SENT
  PENDING
  PAID
  FAILED
  CANCELLED
  EXPIRED
  REFUNDED
}

enum ReservationSource {
  WEBSITE
  ADMIN
  PHONE
  EMAIL
  MESSENGER
  WHATSAPP
  BOOKING
  AIRBNB
  MANUAL
  OTHER
}

enum PaymentProvider {
  STRIPE
  PRZELEWY24
  PAYU
  TPAY
  MANUAL_TRANSFER
  OTHER
}

enum PricingRuleType {
  SEASONAL
  WEEKEND
  EVENT
  CUSTOM
}

enum EmailLogStatus {
  PENDING
  SENT
  FAILED
}

enum AdminUserRole {
  ADMIN
  MANAGER
  STAFF
}

model Apartment {
  id                  String          @id @default(uuid()) @db.Uuid
  name                String
  slug                String          @unique
  address             String?
  city                String?
  description         String?
  maxGuests           Int             @map("max_guests")
  basePricePerNight   Decimal         @map("base_price_per_night") @db.Decimal(10, 2)
  cleaningFee         Decimal         @map("cleaning_fee") @db.Decimal(10, 2)
  depositAmount       Decimal         @map("deposit_amount") @db.Decimal(10, 2)
  currency            String          @default("PLN")
  minimumNights       Int             @map("minimum_nights") @default(1)
  defaultCheckInTime  String?         @map("default_check_in_time")
  defaultCheckOutTime String?         @map("default_check_out_time")
  googleCalendarId    String?         @map("google_calendar_id")
  isActive            Boolean         @map("is_active") @default(true)
  createdAt           DateTime        @map("created_at") @default(now())
  updatedAt           DateTime        @map("updated_at") @updatedAt
  reservations        Reservation[]
  pricingRules        PricingRule[]
  calendarBlocks      CalendarBlock[]

  @@index([isActive])
  @@map("apartments")
}

model Guest {
  id               String        @id @default(uuid()) @db.Uuid
  firstName        String        @map("first_name")
  lastName         String        @map("last_name")
  email            String
  phone            String
  country          String?
  city             String?
  language         String?       @default("pl")
  marketingConsent Boolean       @map("marketing_consent") @default(false)
  termsAccepted    Boolean       @map("terms_accepted") @default(false)
  rodoAccepted     Boolean       @map("rodo_accepted") @default(false)
  notes            String?
  createdAt        DateTime      @map("created_at") @default(now())
  updatedAt        DateTime      @map("updated_at") @updatedAt
  reservations     Reservation[]
  emailLogs        EmailLog[]

  @@index([email])
  @@index([phone])
  @@map("guests")
}

model Reservation {
  id                  String             @id @default(uuid()) @db.Uuid
  reservationNumber   String             @map("reservation_number") @unique
  apartmentId         String             @map("apartment_id") @db.Uuid
  guestId             String             @map("guest_id") @db.Uuid
  checkInDate         DateTime           @map("check_in_date") @db.Date
  checkOutDate        DateTime           @map("check_out_date") @db.Date
  nightsCount         Int                @map("nights_count")
  guestsCount         Int                @map("guests_count")
  pricePerNight       Decimal            @map("price_per_night") @db.Decimal(10, 2)
  accommodationAmount Decimal            @map("accommodation_amount") @db.Decimal(10, 2)
  cleaningFee         Decimal            @map("cleaning_fee") @db.Decimal(10, 2)
  depositAmount       Decimal            @map("deposit_amount") @db.Decimal(10, 2)
  discountAmount      Decimal            @map("discount_amount") @default(0) @db.Decimal(10, 2)
  totalAmount         Decimal            @map("total_amount") @db.Decimal(10, 2)
  amountToPayNow      Decimal            @map("amount_to_pay_now") @db.Decimal(10, 2)
  paidAmount          Decimal            @map("paid_amount") @default(0) @db.Decimal(10, 2)
  currency            String             @default("PLN")
  status              ReservationStatus  @default(DRAFT)
  paymentStatus       PaymentStatus      @map("payment_status") @default(CREATED)
  source              ReservationSource  @default(WEBSITE)
  createdByType       String             @map("created_by_type") @default("customer")
  calendarEventId     String?            @map("calendar_event_id")
  holdExpiresAt       DateTime?          @map("hold_expires_at")
  confirmedAt         DateTime?          @map("confirmed_at")
  cancelledAt         DateTime?          @map("cancelled_at")
  completedAt         DateTime?          @map("completed_at")
  customerNotes       String?            @map("customer_notes")
  adminNotes          String?            @map("admin_notes")
  createdAt           DateTime           @map("created_at") @default(now())
  updatedAt           DateTime           @map("updated_at") @updatedAt
  apartment           Apartment          @relation(fields: [apartmentId], references: [id], onDelete: Restrict)
  guest               Guest              @relation(fields: [guestId], references: [id], onDelete: Restrict)
  payments            Payment[]
  emailLogs           EmailLog[]

  @@index([apartmentId, checkInDate, checkOutDate])
  @@index([status])
  @@index([paymentStatus])
  @@index([holdExpiresAt])
  @@index([source])
  @@map("reservations")
}

model Payment {
  id                String          @id @default(uuid()) @db.Uuid
  reservationId     String          @map("reservation_id") @db.Uuid
  provider          PaymentProvider @default(STRIPE)
  providerPaymentId String?         @map("provider_payment_id")
  paymentToken      String          @map("payment_token") @unique
  paymentUrl        String?         @map("payment_url")
  amount            Decimal         @db.Decimal(10, 2)
  currency          String          @default("PLN")
  status            PaymentStatus   @default(CREATED)
  paymentExpiresAt  DateTime?       @map("payment_expires_at")
  paymentLinkSentAt DateTime?       @map("payment_link_sent_at")
  paymentLinkSentTo String?         @map("payment_link_sent_to")
  paymentLinkOpenedAt DateTime?     @map("payment_link_opened_at")
  paidAt            DateTime?       @map("paid_at")
  failedAt          DateTime?       @map("failed_at")
  refundedAt        DateTime?       @map("refunded_at")
  rawWebhookPayload Json?           @map("raw_webhook_payload")
  createdAt         DateTime        @map("created_at") @default(now())
  updatedAt         DateTime        @map("updated_at") @updatedAt
  reservation       Reservation     @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@index([providerPaymentId])
  @@index([status])
  @@index([paymentExpiresAt])
  @@map("payments")
}

model PricingRule {
  id             String          @id @default(uuid()) @db.Uuid
  apartmentId    String          @map("apartment_id") @db.Uuid
  name           String
  ruleType       PricingRuleType @map("rule_type") @default(CUSTOM)
  dateFrom       DateTime        @map("date_from") @db.Date
  dateTo         DateTime        @map("date_to") @db.Date
  pricePerNight  Decimal         @map("price_per_night") @db.Decimal(10, 2)
  minimumNights  Int?            @map("minimum_nights")
  daysOfWeek     Json?           @map("days_of_week")
  priority       Int             @default(0)
  isActive       Boolean         @map("is_active") @default(true)
  createdAt      DateTime        @map("created_at") @default(now())
  updatedAt      DateTime        @map("updated_at") @updatedAt
  apartment      Apartment       @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  @@index([apartmentId, dateFrom, dateTo])
  @@index([isActive])
  @@index([priority])
  @@map("pricing_rules")
}

model CalendarBlock {
  id              String    @id @default(uuid()) @db.Uuid
  apartmentId     String    @map("apartment_id") @db.Uuid
  dateFrom        DateTime  @map("date_from") @db.Date
  dateTo          DateTime  @map("date_to") @db.Date
  reason          String?
  calendarEventId String?   @map("calendar_event_id")
  createdBy       String?   @map("created_by")
  createdAt       DateTime  @map("created_at") @default(now())
  updatedAt       DateTime  @map("updated_at") @updatedAt
  apartment       Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  @@index([apartmentId, dateFrom, dateTo])
  @@map("calendar_blocks")
}

model EmailLog {
  id                String         @id @default(uuid()) @db.Uuid
  reservationId     String?        @map("reservation_id") @db.Uuid
  guestId           String?        @map("guest_id") @db.Uuid
  type              String
  recipientEmail    String         @map("recipient_email")
  subject           String
  status            EmailLogStatus @default(PENDING)
  providerMessageId String?        @map("provider_message_id")
  errorMessage      String?        @map("error_message")
  sentAt            DateTime?      @map("sent_at")
  createdAt         DateTime       @map("created_at") @default(now())
  updatedAt         DateTime       @map("updated_at") @updatedAt
  reservation       Reservation?   @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  guest             Guest?         @relation(fields: [guestId], references: [id], onDelete: SetNull)

  @@index([reservationId])
  @@index([guestId])
  @@index([status])
  @@map("email_logs")
}

model AppSetting {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  value       String
  type        String
  description String?
  createdAt   DateTime @map("created_at") @default(now())
  updatedAt   DateTime @map("updated_at") @updatedAt

  @@map("app_settings")
}

model AdminUser {
  id          String        @id @default(uuid()) @db.Uuid
  email       String        @unique
  name        String?
  role        AdminUserRole @default(ADMIN)
  isActive    Boolean       @map("is_active") @default(true)
  lastLoginAt DateTime?     @map("last_login_at")
  createdAt   DateTime      @map("created_at") @default(now())
  updatedAt   DateTime      @map("updated_at") @updatedAt

  @@index([role])
  @@index([isActive])
  @@map("admin_users")
}
